NODE_ENV=development
PORT=4000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/bidnsteal
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=bidnsteal:

# Auth + cookies
JWT_SECRET=change-this-to-a-long-random-secret
COOKIE_NAME=bidnsteal_session
CSRF_COOKIE_NAME=bidnsteal_csrf
SESSION_TTL_MS=604800000
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
TRUST_PROXY=false

# Allowed frontend origins
CLIENT_URLS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
SITE_NAME=BidnSteal
SITE_URL=http://localhost:3000
SUPPORT_EMAIL=support@bidnsteal.com
SUPPORT_PHONE=
SUPPORT_WHATSAPP_NUMBER=
FACEBOOK_URL=

# Uploads stored on your VPS/local disk
UPLOADS_DIR=uploads
UPLOAD_MAX_FILE_SIZE_BYTES=10485760

# Request limits
BODY_SIZE_LIMIT=1mb
URLENCODED_PARAMETER_LIMIT=200
PUBLIC_RATE_LIMIT_WINDOW_MS=900000
PUBLIC_RATE_LIMIT_MAX=900
WRITE_RATE_LIMIT_WINDOW_MS=600000
WRITE_RATE_LIMIT_MAX=180
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Bootstrap
ADMIN_EMAIL=admin@bidnsteal.com
ADMIN_PASSWORD=change-this-admin-password
AUTO_SEED=false
